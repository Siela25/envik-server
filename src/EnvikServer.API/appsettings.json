{
  "ConnectionStrings": {
    "DefaultConnection": "Host=[HOST];Database=[DATABASE_NAME];Username=[DATABASE_USER_NAME];Password=[DATABASE_PASSWORD]",
    "Redis": "[HOST]:[PORT]"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "here-proper-secret-key",
    "Issuer": "envik-server",
    "Audience": "envik-client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  }
}
